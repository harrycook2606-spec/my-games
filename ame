<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Unblocked Games</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <header>
        <h1>Game Portal</h1>
        <input type="text" id="searchBar" placeholder="Search for a game..." onkeyup="filterGames()">
    </header>

    <main id="gameGrid">
        <!-- Games will be injected here by JavaScript -->
    </main>

    <!-- Modal for playing games -->
    <div id="gameModal" class="modal">
        <div class="modal-content">
            <span class="close" onclick="closeGame()">&times;</span>
            <iframe id="gameFrame" src="" frameborder="0"></iframe>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>
